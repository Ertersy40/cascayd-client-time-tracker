{
  "name": "cascayd-timetracker",
  "version": "1.0.0",
  "description": "Client work time tracker for Cascayd",
  "main": "main.js",
  "author": "Cascayd",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/cascayd-timetracker.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "node package-portable.js",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.cascayd.timetracker",
    "productName": "Cascayd TimeTracker",
    "files": [
      "main.js",
      "dashboard.html",
      "categorization-prompt.txt",
      ".env",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "YOUR_USERNAME",
      "repo": "cascayd-timetracker"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1017.0",
    "active-win": "^9.0.0",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
